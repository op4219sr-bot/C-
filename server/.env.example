# ===========================================================================
# LightC License Server 配置
# 复制为 .env 并填入真实密钥
# ===========================================================================

# 监听地址
HOST=0.0.0.0
PORT=8088

# SQLite 数据库路径
DB_PATH=./data/license.db

# ---------------------------------------------------------------------------
# 密钥：必须与 Rust 端 src-tauri/src/license/mod.rs 中的常量保持一致
# 生产部署前请重新生成并同步到客户端
# ---------------------------------------------------------------------------

# Ed25519 私钥（32 字节 hex）—— 用于签发 license token
LICENSE_PRIVKEY_HEX=36576f3105baa43de5f9f3cbc8096681c0cca44fcae7d34c65a86159abb106ab
# Ed25519 公钥（32 字节 hex）—— 仅用于自检
LICENSE_PUBKEY_HEX=cec68f495cb80ecf072ff70bdfa82412435fc6110994be520e898205eec5cf8c

# 与客户端通信的 HMAC 签名 secret（32 字节 hex）
APP_SIGN_SECRET_HEX=f39681045d3040cc3ca8c1b7b6cf5ead946962fd30c38a4bf1fcbcc82db9d950

# ---------------------------------------------------------------------------
# 管理后台
# ---------------------------------------------------------------------------

# 管理员用户名 / 密码（Basic Auth）
ADMIN_USER=admin
ADMIN_PASS=changeme

# ---------------------------------------------------------------------------
# 其他
# ---------------------------------------------------------------------------

# 客户端请求频率限制（每分钟，单 IP），0 表示不限制
RATE_LIMIT_PER_MIN=60

# 是否允许跨域调试（生产请设为 false）
ALLOW_DEV_CORS=false

# ---------------------------------------------------------------------------
# AI 智能清理顾问（Proxy 模式：服务端代理 LLM 调用）
# ---------------------------------------------------------------------------

# 智谱 GLM API Key（在 https://open.bigmodel.cn 申请，GLM-4-Flash 免费）
# 留空则关闭 Proxy 模式（用户只能用 BYOK 自带 key）
GLM_API_KEY=

# LLM endpoint（默认智谱 GLM，OpenAI 兼容格式）
GLM_ENDPOINT=https://open.bigmodel.cn/api/paas/v4/chat/completions

# LLM 模型名
GLM_MODEL=glm-4-flash

# 每个卡密每月 AI 分析免费次数（0 表示不限制）
AI_MONTHLY_QUOTA=30
